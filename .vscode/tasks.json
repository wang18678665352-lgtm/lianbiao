{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: gcc.exe 生成活动文件",
            "type": "shell",
            "command": "E:/bianyiqi/c/mingw64/bin/gcc.exe", // 这里也要填对路径
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}